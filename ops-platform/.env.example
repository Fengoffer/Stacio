# Runtime
NODE_ENV=production
COMPOSE_PROJECT_NAME=stacio-ops
WEB_PORT=8081
API_PORT=8080
WEB_BIND_HOST=127.0.0.1
API_BIND_HOST=127.0.0.1
VITE_API_BASE_URL=/api/v1
VITE_DEMO_MODE=false
JWT_SECRET=replace-with-a-long-random-secret
ANALYTICS_HASH_KEY=replace-with-a-separate-random-secret
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_EXPIRES_DAYS=30
TRUST_PROXY=false
BOOTSTRAP_OWNER_EMAIL=owner@example.com
BOOTSTRAP_OWNER_PASSWORD=replace-with-a-strong-password
BOOTSTRAP_OWNER_NAME=Stacio Owner

# Connector secret encryption
# Generate with: openssl rand -base64 32
CONNECTOR_ENCRYPTION_KEY_BASE64=replace-with-a-base64-encoded-32-byte-key

# Public client APIs
PUBLIC_FEEDBACK_RATE_LIMIT_MAX=30
PUBLIC_FEEDBACK_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_TELEMETRY_RATE_LIMIT_MAX=120
PUBLIC_TELEMETRY_RATE_LIMIT_WINDOW_SECONDS=60

# PostgreSQL
DATA_ROOT=./data
DATABASE_URL=postgres://stacio_ops:change-me@postgres:5432/stacio_ops
POSTGRES_USER=stacio_ops
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stacio_ops
DATABASE_AUTO_MIGRATE=true
DATABASE_SEED_DEFAULTS=true
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Container resource and log limits
API_MEMORY_LIMIT=512m
WORKER_MEMORY_LIMIT=384m
WEB_MEMORY_LIMIT=128m
POSTGRES_MEMORY_LIMIT=512m
REDIS_MEMORY_LIMIT=128m
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Redis / queue
REDIS_URL=redis://redis:6379

# Object storage, S3-compatible
S3_ENDPOINT=https://object-storage.example.com
S3_REGION=auto
S3_BUCKET=stacio-ops
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=https://cdn.example.com/stacio-ops
S3_OBJECT_PREFIX=products/stacio
S3_PRESIGN_EXPIRES_SECONDS=900

# SMTP, planned for Feishu mail
SMTP_HOST=smtp.feishu.cn
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ops@example.com
SMTP_PASSWORD=change-me
SMTP_FROM="Stacio Ops <ops@example.com>"
SMTP_DRY_RUN=false

# Notification policy
# Low/normal priority admin_* notifications are delayed during this window. High/urgent alerts bypass it.
NOTIFICATION_QUIET_HOURS_START=22:00
NOTIFICATION_QUIET_HOURS_END=08:00
NOTIFICATION_QUIET_HOURS_TIME_ZONE=Asia/Shanghai

# GitHub connector
GITHUB_OWNER=your-org
GITHUB_REPOSITORY=stacio
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

# Agent API
AGENT_API_KEY_PEPPER=change-me
# Preferred production format. productIds=[] means global product access; scopes=["*"] means all Agent scopes.
AGENT_API_KEYS_JSON=[{"id":"codex-feedback","key":"replace-with-codex-key","name":"Codex feedback triage","productIds":["stacio"],"scopes":["feedback:read","feedback:write_analysis","feedback:write_draft","issues:read","customers:read","licenses:read","notifications:write_draft","actions:propose","releases:read","releases:write_draft"],"expiresAt":"2099-01-01T00:00:00.000Z"}]
# Legacy single global key fallback. Leave empty when AGENT_API_KEYS_JSON is configured.
AGENT_API_KEY=replace-with-a-scoped-agent-key

# License signing
# Generate an Ed25519 private key PEM, then base64 the PEM for LICENSE_PRIVATE_KEY_BASE64.
# The public key is for clients/offline validators and should match the private key.
LICENSE_PRIVATE_KEY_BASE64=
LICENSE_PUBLIC_KEY_BASE64=
