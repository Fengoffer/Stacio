{
  "name": "stacio-ops-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:worker": "tsx watch apps/api/src/jobs/worker.ts",
    "dev:web": "vite --config apps/web/vite.config.ts --host 127.0.0.1",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx apps/api/src/db/cli.ts migrate",
    "db:seed": "tsx apps/api/src/db/cli.ts seed",
    "test": "vitest run",
    "verify:docker-static": "node scripts/verify-docker-static.mjs",
    "typecheck": "tsc -p apps/api/tsconfig.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit",
    "build:api": "tsc -p apps/api/tsconfig.json",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build": "npm run build:api && npm run build:web"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/s3-request-presigner": "^3.1084.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.2.0",
    "@tanstack/react-router": "^1.121.2",
    "@tanstack/react-table": "^8.21.3",
    "bullmq": "^5.56.4",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.4.0",
    "ioredis": "^5.6.1",
    "lucide-react": "^1.24.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.13",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.3",
    "vitest": "^3.2.4"
  }
}
